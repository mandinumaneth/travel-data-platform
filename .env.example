# Snowflake
SNOWFLAKE_ACCOUNT=YOUR_SNOWFLAKE_ACCOUNT
SNOWFLAKE_USER=YOUR_SNOWFLAKE_USERNAME
SNOWFLAKE_PASSWORD=YOUR_SNOWFLAKE_PASSWORD
SNOWFLAKE_DATABASE=TRAVEL_DW
SNOWFLAKE_WAREHOUSE=YOUR_SNOWFLAKE_WAREHOUSE
SNOWFLAKE_ROLE=YOUR_SNOWFLAKE_ROLE
SNOWFLAKE_SCHEMA=BRONZE

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=travel_db
POSTGRES_USER=travel_user
POSTGRES_PASSWORD=YOUR_POSTGRES_PASSWORD

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_FLIGHT_TOPIC=flight-events
KAFKA_POLICY_TOPIC=policy-events
KAFKA_FLIGHT_CONSUMER_GROUP=travel-flight-consumer
KAFKA_MONITOR_CONSUMER_GROUP=travel-flight-monitor

# OpenSky
OPENSKY_API_URL=https://opensky-network.org/api/states/all
OPENSKY_POLL_SECONDS=30
OPENSKY_RETRY_SECONDS=60

# Airflow
AIRFLOW_ADMIN_USERNAME=airflow
AIRFLOW_ADMIN_PASSWORD=airflow
AIRFLOW_WEBSERVER_SECRET_KEY=YOUR_AIRFLOW_WEBSERVER_SECRET_KEY
AIRFLOW_FERNET_KEY=YOUR_AIRFLOW_FERNET_KEY
AIRFLOW_EMAIL_NOTIFICATIONS=false
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://travel_user:YOUR_POSTGRES_PASSWORD@postgres:5432/travel_db

# Paths
PROJECT_ROOT=.

# Streamlit
STREAMLIT_SERVER_PORT=8501
